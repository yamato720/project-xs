          "state_ports": [
            "RegPort r_stage",
            "RegPort z_stage",
            "RegPort p_stage",
            "RegPort metrics_stage"
          ]
        },
        "components": [
          {
            "name": "residual_component",
            "role": "计算 r = b - ax",
            "reads": [
              "b",
